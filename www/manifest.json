{
  "name": "NUCLEARFF - Fantasy Football Analytics",
  "short_name": "NUCLEARFF",
  "description": "Advanced fantasy football analytics and league management platform optimized for mobile devices",
  "start_url": "/",
  "display": "standalone",
  "orientation": "portrait-primary",
  "theme_color": "#007AFF",
  "background_color": "#FFFFFF",
  "scope": "/",
  "lang": "en-US",
  "dir": "ltr",
  
  "icons": [
    {
      "src": "nuclearff/nuclearff-navbar-icon-color.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "nuclearff/nuclearff-navbar-icon-color.png", 
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "nuclearff/nuclearff-navbar-icon-dark.png",
      "sizes": "192x192", 
      "type": "image/png",
      "purpose": "any"
    }
  ],
  
  "screenshots": [
    {
      "src": "screenshots/mobile-home.png",
      "sizes": "390x844",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Home screen showing league overview and quick actions"
    },
    {
      "src": "screenshots/mobile-data.png", 
      "sizes": "390x844",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Data management interface with league statistics"
    },
    {
      "src": "screenshots/mobile-charts.png",
      "sizes": "390x844", 
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Interactive charts and visualizations"
    }
  ],
  
  "categories": [
    "sports",
    "entertainment", 
    "social",
    "productivity"
  ],
  
  "shortcuts": [
    {
      "name": "View League Data",
      "short_name": "League Data",
      "description": "Quickly access your league statistics and player data",
      "url": "/?tab=data",
      "icons": [
        {
          "src": "icons/data-shortcut.png",
          "sizes": "96x96"
        }
      ]
    },
    {
      "name": "View Charts",
      "short_name": "Charts", 
      "description": "Jump directly to performance visualizations",
      "url": "/?tab=viz",
      "icons": [
        {
          "src": "icons/chart-shortcut.png",
          "sizes": "96x96"
        }
      ]
    },
    {
      "name": "Refresh Data",
      "short_name": "Refresh",
      "description": "Update league data with latest information", 
      "url": "/?action=refresh",
      "icons": [
        {
          "src": "icons/refresh-shortcut.png",
          "sizes": "96x96"
        }
      ]
    }
  ],
  
  "share_target": {
    "action": "/share",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  
  "protocol_handlers": [
    {
      "protocol": "web+nuclearff",
      "url": "/league?id=%s"
    }
  ],
  
  "prefer_related_applications": false,
  "related_applications": [
    {
      "platform": "play",
      "url": "https://play.google.com/store/apps/details?id=com.nuclearff.app",
      "id": "com.nuclearff.app"
    },
    {
      "platform": "itunes",
      "url": "https://apps.apple.com/app/nuclearff/id123456789"
    }
  ],
  
  "edge_side_panel": {
    "preferred_width": 400
  },
  
  "launch_handler": {
    "client_mode": "focus-existing"
  },
  
  "handle_links": "preferred",
  
  "capture_links": "existing-client-navigate"
}